# Convex Configuration
VITE_CONVEX_URL=

# OAuth Provider Configuration
# GitHub OAuth
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Callback URL: https://your-convex-backend.convex.site/api/auth/callback/github
AUTH_GITHUB_ID=your_github_client_id
AUTH_GITHUB_SECRET=your_github_client_secret

# Google OAuth
# Create a Google OAuth App at: https://console.cloud.google.com/
# Callback URL: https://your-convex-backend.convex.site/api/auth/callback/google
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret

# Site URL (required for OAuth callbacks)
CONVEX_SITE_URL=http://localhost:5173  # Change to your production URL in production

# Resend Configuration (for email authentication)
RESEND_API_KEY=your_resend_api_key
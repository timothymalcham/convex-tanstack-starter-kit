{
  "name": "tanstack-start-example-convex-trellaux",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "npx convex dev --once && concurrently -r npm:dev:web npm:dev:db",
    "dev:web": "vite dev",
    "dev:db": "convex dev --run board:seed",
    "build": "vite build && tsc --noEmit",
    "start": "vite start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-beta.0",
    "@convex-dev/react-query": "0.0.0-alpha.8",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-query-devtools": "^5.66.0",
    "@tanstack/react-router": "^1.121.27",
    "@tanstack/react-router-devtools": "^1.121.27",
    "@tanstack/react-router-with-query": "^1.121.27",
    "@tanstack/react-start": "^1.121.32",
    "concurrently": "^8.2.2",
    "convex": "^1.19.0",
    "ky": "^1.7.4",
    "msw": "^2.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.5.1",
    "redaxios": "^0.5.1",
    "tailwind-merge": "^2.6.0",
    "tiny-invariant": "^1.3.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.4",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.7.2",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
